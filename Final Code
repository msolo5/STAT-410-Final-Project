# Create cinderella teams confidence intervals
bivariate_ci <- model_vars |>
  map_dfr(function(var) {
    formula <- as.formula(paste("tournament_wins ~ `", var, "`", sep = ""))
    model <- lm(formula, data = model_df)
    ci <- confint(model, level = 0.95)
    data.frame(
      variable = var,
      estimate = coef(model)[2],
      conf_low = ci[2, 1],
      conf_high = ci[2, 2],
      p_value = summary(model)$coefficients[2, 4],
      r_squared = summary(model)$r.squared
    )
  })

print(bivariate_ci)

