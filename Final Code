  arrange(desc(r_squared)) |>
  slice_head(n = 3) |>
  pull(term)

# Build a multivariate model with those 3 variables
formula_top3 <- as.formula(
  paste("tournament_wins ~", paste0("`", top3_vars, "`", collapse = " + "))
)

model_top3 <- lm(formula_top3, data = model_df)

model_summary <- summary(model_top3)
model_summary

# Plot final model results
model_tidy <- tidy(model_top3, conf.int = TRUE) |>
  filter(term != "(Intercept)") |>
  mutate(
    term = case_when(
      term == "3P_O"  ~ "3P% Offense",
      term == "2P_O"  ~ "2P% Offense",
      term == "ADJDE" ~ "Adj. Def. Efficiency",
      TRUE ~ term
    ),
    significant = p.value < 0.05
  )

r2 <- round(model_summary$r.squared, 4)
adj_r2 <- round(model_summary$adj.r.squared, 4)
pval <- round(pf(model_summary$fstatistic[1],
                    model_summary$fstatistic[2],
                    model_summary$fstatistic[3],
                    lower.tail = FALSE), 4)

metric_labels <- c(
  paste0("R^2 = ", r2),
  paste0("Adj. R^2 = ", adj_r2),
  paste0("F p-value = ", pval)
)

metrics_df <- data.frame(
  label = metric_labels,
  x = 1:3,
  y = 0.5
)

p1 <- ggplot(metrics_df, aes(x = x, y = y, label = label)) +
  geom_tile(fill = "gray95", color = "gray80", width = 0.9, height = 0.8) +
  geom_text(size = 5, fontface = "bold") +
  xlim(0.5, 3.5) + ylim(0, 1) +
  theme_void() +
  labs(title = "Model Summary: Cinderella Teams")

p2 <- ggplot(model_tidy, aes(x = reorder(term, -p.value), y = p.value,
